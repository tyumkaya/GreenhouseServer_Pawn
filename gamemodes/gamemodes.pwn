public OnPlayerConnect(playerid)
{
	ResetPlayerAccountData(playerid);
	ResetPlayerGreenhouses(playerid);
	GetPlayerName(playerid, GetPlayer(playerid, pName), MAX_PLAYER_NAME);

	SetTimerEx("TimerConnectToServer", 300, false, "i", playerid);
	return 1;
}

public OnPlayerDisconnect(playerid, reason)
{
	SaveAndUnloadPlayerGreenhouses(playerid);
	GetPlayer(playerid, pID) = 0;
	GetPlayer(playerid, pLogin) = false;
	return 1;
}

public OnPlayerRequestClass(playerid, classid)
{
	SetPlayerPos(playerid, 217.8511, -98.4865, 1005.2578);
	SetPlayerFacingAngle(playerid, 113.8861);
	SetPlayerInterior(playerid, 15);
	SetPlayerCameraPos(playerid, 215.2182, -99.5546, 1006.4);
	SetPlayerCameraLookAt(playerid, 217.8511, -98.4865, 1005.2578);
	ApplyAnimation(playerid, "benchpress", "gym_bp_celebrate", 4.1, true, false, false, false, 0, SYNC_NONE);
	return 1;
}

public OnPlayerSpawn(playerid)
{
	SetPlayerInterior(playerid, 0);
	return 1;
}

